resource/
*.mp4
*.avi
*.mov
*.mkv
*.mp3
*.wav
*.srt
*.vtt

# 本地模式音频文件（不提交）
EastonJiang/public/audios/*/
EastonJiang/public/subtitles/*/
!EastonJiang/public/audios/mock-data.json

# Python 相关
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# pyenv
.python-version

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
*.bak
*.cache

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.*.local

# Node modules（在子目录 EastonJiang/ 中）
node_modules/

# 构建输出
build/
dist/
*.tgz

