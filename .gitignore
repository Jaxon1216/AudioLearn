# Alan 音频学习应用 - 主项目 .gitignore

# 原始视频文件（太大，不应提交到 git）
raw_videos/
*.mp4
*.avi
*.mov
*.mkv

# 处理后的音频和字幕文件（建议使用 Supabase Storage）
# 如果要提交到 git，建议使用 Git LFS
processed/
*.mp3
*.wav
*.srt
*.vtt

# 临时文档（开发过程中的状态文档）
CHANGELOG.md
CURRENT_STATUS.md
DEPLOYMENT_CHECKLIST.md
FINAL_STATUS.md
INSTALLATION_COMPLETE.md
PROCESSING_STATUS.md
PROJECT_OPTIMIZATION.md
PROJECT_SUMMARY.md
READY_TO_DEPLOY.md
about.md

# Python 相关
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# pyenv
.python-version

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
*.bak
*.cache

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.*.local

# Node modules（在子目录 alan/ 中）
node_modules/

# 构建输出
build/
dist/
*.tgz

# 测试覆盖率
coverage/
.nyc_output/

# 其他
*.pid
*.seed
*.pid.lock
